---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getPublicAsset } from '../../lib/publicAsset';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const postsWithImages = posts.map((post) => ({
  post,
  image: getPublicAsset(post.data.image),
}));

const formatDate = (date: string) => new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: '2-digit',
  year: 'numeric',
}).format(new Date(`${date}T12:00:00`));
---

<SiteLayout title="Resources - Editnew" description="Browse support, training, and product resources from Editnew.">
  <section class="resource-hero shell">
    <p class="eyebrow">Support library</p>
    <h1 class="page-title">Resources for using S.A.M.</h1>
    <p class="lead">
      Guides, release notes, embedded signage layouts, troubleshooting references, and client-facing training material.
    </p>
  </section>

  <section class="shell" aria-label="All resources">
    <div class="section-head">
      <h2>All resources</h2>
      <span class="meta">{posts.length.toString().padStart(2, '0')} published</span>
    </div>

    {postsWithImages.length > 0 ? (
      <div class="resource-list">
        {postsWithImages.map(({ post, image }) => (
          <a class="resource-card featured" href={`/news/${post.data.slug}`}>
            <div>
              <div class="card-kicker">
                <span class="meta">{formatDate(post.data.date)}</span>
                {post.data.location && <span class="meta">{post.data.location}</span>}
              </div>
              <h2 class="card-title">{post.data.title}</h2>
              {post.data.excerpt && <p class="card-excerpt">{post.data.excerpt}</p>}
              {post.data.tags.length > 0 && (
                <ul class="tag-list" aria-label="Tags">
                  {post.data.tags.slice(0, 5).map((tag) => <li class="tag">{tag}</li>)}
                </ul>
              )}
            </div>
            <div
              class="card-media"
              style={image ? `--resource-image: url("${image}")` : undefined}
              aria-hidden="true"
            />
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>No resources published yet</h2>
        <p>Published markdown files committed by the current automation will appear here without changing the n8n workflow.</p>
      </div>
    )}
  </section>
</SiteLayout>
