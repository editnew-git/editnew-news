---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getPublicAsset } from '../lib/publicAsset';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const latest = posts[0];
const recent = posts.slice(1, 5);
const latestImage = getPublicAsset(latest?.data.image);
const formatDate = (date: string) => new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: '2-digit',
  year: 'numeric',
}).format(new Date(`${date}T12:00:00`));
---

<SiteLayout title="Editnew Resource Center" description="Support, training, and product resources for Editnew and S.A.M.">
  <section class="home-hero shell">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">S.A.M support and training</p>
        <h1 class="display">Editnew Resource Center</h1>
        <p class="lead">
          Practical guides, product notes, embedded screen-layout examples, and support updates for clients using S.A.M and Editnew services.
        </p>
      </div>
      <aside class="hero-panel" aria-label="About S.A.M">
        <img src="/images/brand/sam-logo.png" alt="S.A.M logo" width="1000" height="1080" />
        <p>
          Use this space for nontechnical walkthroughs, client-facing documentation, training records, and technical notes when they help people use the product.
        </p>
      </aside>
    </div>
  </section>

  <section class="shell" aria-label="Latest resource">
    <div class="section-head">
      <h2>Latest resource</h2>
      <a class="text-link" href="/news/">View all resources</a>
    </div>

    {latest ? (
      <a
        class="resource-card featured"
        href={`/news/${latest.data.slug}`}
      >
        <div>
          <div class="card-kicker">
            <span class="meta">{formatDate(latest.data.date)}</span>
            {latest.data.location && <span class="meta">{latest.data.location}</span>}
          </div>
          <h3 class="card-title">{latest.data.title}</h3>
          {latest.data.excerpt && <p class="card-excerpt">{latest.data.excerpt}</p>}
          {latest.data.tags.length > 0 && (
            <ul class="tag-list" aria-label="Tags">
              {latest.data.tags.slice(0, 4).map((tag) => <li class="tag">{tag}</li>)}
            </ul>
          )}
        </div>
        <div
          class="card-media"
          style={latestImage ? `--resource-image: url("${latestImage}")` : undefined}
          aria-hidden="true"
        />
      </a>
    ) : (
      <div class="empty-state">
        <h2>No resources published yet</h2>
        <p>When Pressly commits markdown into <code>src/content/news</code>, published resources will appear here automatically.</p>
      </div>
    )}
  </section>

  {recent.length > 0 && (
    <section class="shell" aria-label="Recent resources">
      <div class="section-head">
        <h2>Recent resources</h2>
      </div>
      <div class="resource-grid">
        {recent.map((post) => (
          <a class="resource-card" href={`/news/${post.data.slug}`}>
            <div class="card-kicker">
              <span class="meta">{formatDate(post.data.date)}</span>
              {post.data.location && <span class="meta">{post.data.location}</span>}
            </div>
            <h3 class="card-title">{post.data.title}</h3>
            {post.data.excerpt && <p class="card-excerpt">{post.data.excerpt}</p>}
            {post.data.tags.length > 0 && (
              <ul class="tag-list" aria-label="Tags">
                {post.data.tags.slice(0, 3).map((tag) => <li class="tag">{tag}</li>)}
              </ul>
            )}
          </a>
        ))}
      </div>
    </section>
  )}
</SiteLayout>
