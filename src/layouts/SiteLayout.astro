---
interface Props { title: string; description?: string; }
const { title, description = 'Support, training, and product resources for Editnew and S.A.M.' } = Astro.props;
---
<!doctype html>
<html lang="en"><head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} /><meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" /><link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
  <title>{title}</title>
</head><body>
  <header class="site-header"><div class="header-inner shell">
    <a class="brand" href="/" aria-label="Editnew Support home"><img src="/images/brand/sam-logo.png" alt="S.A.M." width="1000" height="1080" /><span class="brand-copy"><strong>EDITNEW</strong><small>Support Centre</small></span></a>
    <nav aria-label="Primary navigation"><a href="/">Home</a><a href="/news/">Browse guides</a><a class="nav-external" href="https://editnew.ca/" target="_blank" rel="noreferrer">Editnew.ca <span aria-hidden="true">↗</span></a></nav>
  </div></header>
  <main><slot /></main>
  <footer class="site-footer"><div class="shell footer-inner"><div><strong>Editnew Support Centre</strong><span>Practical resources for S.A.M.</span></div><a href="mailto:info@editnew.ca">Contact Editnew support</a><span>© {new Date().getFullYear()} Editnew Inc.</span></div></footer>
</body></html>

<style is:global>
  :root { --ink:#17202a; --muted:#5c6876; --paper:#f7f8fa; --panel:#fff; --line:#dce2e8; --blue:#4aa4d7; --blue-dark:#1473aa; --blue-pale:#e8f5fc; --gold:#b18760; --shadow:0 14px 38px rgba(21,47,67,.08); color:var(--ink); background:var(--paper); font-family:'DM Sans',Arial,sans-serif; }
  *{box-sizing:border-box} html{scroll-behavior:smooth} body{min-width:320px;margin:0;background:var(--paper)} img{max-width:100%} a{color:inherit} button,input{font:inherit}.shell{width:min(1160px,calc(100% - 2rem));margin:0 auto}.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
  .site-header{position:sticky;top:0;z-index:20;border-bottom:1px solid var(--line);background:rgba(255,255,255,.94);backdrop-filter:blur(14px)}.header-inner,.footer-inner{display:flex;align-items:center;justify-content:space-between;gap:1.25rem}.header-inner{min-height:4.7rem}.brand{display:inline-flex;align-items:center;gap:.7rem;text-decoration:none}.brand img{display:block;width:auto;height:2.65rem;max-width:3rem;object-fit:contain}.brand-copy{display:grid;gap:.1rem;line-height:1}.brand-copy strong{font-family:'Manrope',sans-serif;font-size:.92rem;letter-spacing:.09em}.brand-copy small{color:var(--muted);font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase}nav{display:flex;align-items:center;gap:clamp(.75rem,2.5vw,1.7rem);color:#45515e;font-size:.9rem;font-weight:600}nav a{text-decoration:none}nav a:hover,.link:hover{color:var(--blue-dark)}.nav-external{display:inline-flex;gap:.3rem;align-items:center}
  .site-footer{margin-top:clamp(3rem,8vw,6rem);border-top:1px solid var(--line);background:#fff;color:var(--muted);font-size:.84rem}.footer-inner{min-height:5.75rem;flex-wrap:wrap;padding:1rem 0}.footer-inner div{display:grid;gap:.25rem}.footer-inner strong{color:var(--ink)}.footer-inner a{color:var(--blue-dark);font-weight:700;text-decoration:none}
  .hero{padding:clamp(3.75rem,8vw,7.25rem) 0 clamp(3rem,6vw,5rem);background:linear-gradient(150deg,#fff 0%,#f4fbff 64%,#edf7fb 100%);border-bottom:1px solid var(--line)}.hero-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(15rem,20rem);gap:clamp(2rem,6vw,5rem);align-items:center}.eyebrow{margin:0 0 1rem;color:var(--blue-dark);font-size:.75rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase}.display,.page-title,.article-title{margin:0;font-family:'Manrope',sans-serif;letter-spacing:-.045em;line-height:1.04}.display{max-width:760px;font-size:clamp(2.7rem,6vw,5.5rem)}.page-title{max-width:760px;font-size:clamp(2.3rem,5vw,4.4rem)}.article-title{max-width:850px;font-size:clamp(2.15rem,4.8vw,4.35rem)}.lead{max-width:690px;margin:1.25rem 0 0;color:#475565;font-size:clamp(1.05rem,1.75vw,1.22rem);line-height:1.65}.product-card{padding:1.5rem;border:1px solid #cde4f1;border-radius:1.1rem;background:#fff;box-shadow:var(--shadow)}.product-card img{display:block;width:auto;height:6.7rem;max-width:100%;margin:0 auto 1rem;object-fit:contain}.product-card p{margin:0;color:var(--muted);font-size:.94rem;line-height:1.55}
  .featured-search{max-width:690px;margin-top:1.65rem}.featured-search-control{display:flex;align-items:center;gap:.75rem;padding:.45rem;border:2px solid #88c8e9;border-radius:.9rem;background:#fff;box-shadow:0 16px 38px rgba(20,115,170,.16)}.featured-search-control:focus-within{border-color:var(--blue-dark);box-shadow:0 0 0 4px rgba(74,164,215,.2),0 16px 38px rgba(20,115,170,.16)}.featured-search input{min-width:0;flex:1;padding:.75rem .2rem;border:0;outline:0;background:transparent;color:var(--ink);font-size:1rem}.featured-search input::placeholder{color:#75818d}.featured-search button{flex:none;padding:.82rem 1.15rem;border:0;border-radius:.62rem;background:var(--blue-dark);box-shadow:0 5px 14px rgba(20,115,170,.24);color:#fff;cursor:pointer;font-weight:800;transition:background .18s ease,transform .18s ease}.featured-search button:hover{background:#0d6090;transform:translateY(-1px)}.featured-search button:focus-visible{outline:3px solid rgba(20,115,170,.28);outline-offset:3px}.featured-search>p{margin:.65rem .25rem 0;color:var(--muted);font-size:.8rem}.search-icon{position:relative;flex:none;width:1.05rem;height:1.05rem;margin-left:.65rem;border:2px solid var(--blue-dark);border-radius:50%}.search-icon::after{position:absolute;right:-.35rem;bottom:-.2rem;width:.45rem;height:2px;border-radius:2px;background:var(--blue-dark);content:'';transform:rotate(45deg);transform-origin:left center}.featured-search--browse{margin-top:1.75rem}
  .section{padding-top:clamp(2.75rem,6vw,5rem)}.section-head{display:flex;align-items:end;justify-content:space-between;gap:1rem;margin-bottom:1.25rem}.section-head h2,.section-title{margin:0;font-family:'Manrope',sans-serif;font-size:clamp(1.5rem,3vw,2.15rem);letter-spacing:-.03em}.section-head p{margin:.4rem 0 0;color:var(--muted)}.link{color:var(--blue-dark);font-size:.88rem;font-weight:800;text-decoration:none}
  .category-grid{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:.8rem}.category-card{min-height:9rem;padding:1rem;border:1px solid var(--line);border-radius:.9rem;background:#fff;text-decoration:none;transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease}.category-card:hover{border-color:#9ed3ed;box-shadow:var(--shadow);transform:translateY(-2px)}.category-card strong{display:block;font-family:'Manrope',sans-serif;font-size:1rem;line-height:1.2}.category-card span{display:block;margin-top:.7rem;color:var(--muted);font-size:.85rem;line-height:1.4}.category-mark{display:block;width:1.65rem;height:.32rem;margin-bottom:1rem;border-radius:99px;background:var(--blue)}.category-card:nth-child(2) .category-mark{background:#6eaf8a}.category-card:nth-child(3) .category-mark{background:var(--gold)}.category-card:nth-child(4) .category-mark{background:#d56d64}.category-card:nth-child(5) .category-mark{background:#826eb2}
  .resource-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem}.resource-card{display:flex;flex-direction:column;min-height:15rem;padding:1.25rem;border:1px solid var(--line);border-radius:.95rem;background:var(--panel);color:var(--ink);text-decoration:none;transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease}.resource-card:hover{border-color:#9ed3ed;box-shadow:var(--shadow);transform:translateY(-2px)}.resource-card h2,.resource-card h3{margin:.8rem 0 .65rem;font-family:'Manrope',sans-serif;font-size:1.25rem;letter-spacing:-.02em;line-height:1.23}.resource-card p{margin:0;color:var(--muted);font-size:.93rem;line-height:1.5}.card-footer{margin-top:auto;padding-top:1rem}.badge-row,.tag-list{display:flex;flex-wrap:wrap;gap:.4rem;padding:0;list-style:none}.badge,.tag{display:inline-flex;align-items:center;min-height:1.65rem;padding:.2rem .5rem;border-radius:999px;background:var(--blue-pale);color:#286d95;font-size:.68rem;font-weight:800;letter-spacing:.035em;text-transform:uppercase}.badge--quiet,.tag{border:1px solid var(--line);background:transparent;color:var(--muted)}
  .browse-hero,.article-header{padding:clamp(3rem,6vw,5.5rem) 0 2.4rem;border-bottom:1px solid var(--line);background:#fff}.guide-browser{display:grid;grid-template-columns:16rem minmax(0,1fr);gap:clamp(1.5rem,4vw,3.5rem);padding-top:clamp(2rem,5vw,4rem)}.filters{position:sticky;top:6rem;align-self:start}.filter-label{display:block;margin-bottom:.65rem;color:var(--muted);font-size:.72rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.search-input{width:100%;padding:.8rem .9rem;border:1px solid var(--line);border-radius:.65rem;background:#fff;color:var(--ink)}.search-input:focus{outline:3px solid rgba(74,164,215,.25);border-color:var(--blue)}.filter-list{display:grid;gap:.25rem;margin:.75rem 0 0;padding:0;list-style:none}.filter-button{width:100%;padding:.58rem .65rem;border:0;border-radius:.45rem;background:transparent;color:#43515f;cursor:pointer;font-size:.9rem;text-align:left}.filter-button:hover,.filter-button[aria-pressed='true']{background:var(--blue-pale);color:var(--blue-dark);font-weight:700}.results-head{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1rem}.result-count{color:var(--muted);font-size:.86rem}.browse-list{display:grid;gap:.8rem}.browse-list .resource-card{min-height:0}.browse-list .resource-card[hidden]{display:none}.no-results{margin-top:1rem;padding:1rem;border-radius:.65rem;background:var(--blue-pale);color:#38566b}.empty-state{padding:1.5rem;border:1px dashed #b9cad6;border-radius:.9rem;background:#fff;color:var(--muted);line-height:1.55}.empty-state h2{margin-top:0;color:var(--ink);font-family:'Manrope',sans-serif}
  .breadcrumbs{display:flex;flex-wrap:wrap;gap:.45rem;margin-bottom:1.35rem;color:var(--muted);font-size:.84rem}.breadcrumbs a{color:var(--blue-dark);text-decoration:none}.article-summary{max-width:720px;margin:1rem 0 0;color:#485665;font-size:1.1rem;line-height:1.6}.article-meta{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1.3rem}.article-cover{display:block;width:100%;max-height:32rem;margin:2rem 0 0;border-radius:.9rem;object-fit:cover}.article-layout{display:grid;grid-template-columns:minmax(0,1fr) 16rem;gap:clamp(2rem,6vw,5rem);padding-top:clamp(2.5rem,6vw,4.5rem)}.article-body{max-width:760px;color:#26323e;font-size:1.05rem;line-height:1.75}.article-body>:first-child{margin-top:0}.article-body h2,.article-body h3{color:var(--ink);font-family:'Manrope',sans-serif;letter-spacing:-.025em;line-height:1.2;scroll-margin-top:6.5rem}.article-body h2{margin:2.7rem 0 1rem;padding-top:1.25rem;border-top:1px solid var(--line);font-size:1.65rem}.article-body h3{margin:2rem 0 .75rem;font-size:1.28rem}.article-body p,.article-body ul,.article-body ol{margin:0 0 1.35rem}.article-body li+li{margin-top:.45rem}.article-body a{color:var(--blue-dark);text-underline-offset:.16em}.article-body blockquote{margin:1.8rem 0;padding:1rem 1.2rem;border-left:4px solid var(--blue);border-radius:0 .6rem .6rem 0;background:var(--blue-pale);color:#375267}.article-body img{display:block;max-width:100%;height:auto;margin:2rem auto;border-radius:.7rem}.article-body iframe{display:block;width:100%;max-width:100%;aspect-ratio:16/9;height:auto;margin:2.2rem 0;border:1px solid #b8cbd8;border-radius:.8rem;background:#fff;box-shadow:var(--shadow)}.article-rail{position:sticky;top:6rem;align-self:start;display:grid;gap:1rem}.rail-box{padding:1rem;border:1px solid var(--line);border-radius:.75rem;background:#fff}.rail-box h2{margin:0 0 .7rem;font-family:'Manrope',sans-serif;font-size:1rem}.toc-list{display:grid;gap:.55rem;margin:0;padding:0;list-style:none}.toc-list li[data-depth='3']{padding-left:.75rem}.toc-list a{color:var(--muted);font-size:.85rem;line-height:1.35;text-decoration:none}.toc-list a:hover{color:var(--blue-dark)}.rail-box p{margin:0;color:var(--muted);font-size:.9rem;line-height:1.5}.related{margin-top:clamp(3.5rem,7vw,6rem)}
  @media(max-width:900px){.category-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.resource-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:760px){.site-header{position:static}.header-inner{align-items:flex-start;flex-direction:column;padding:.85rem 0}nav{width:100%;justify-content:space-between;font-size:.83rem}.hero-grid,.guide-browser,.article-layout{grid-template-columns:1fr}.product-card{display:none}.filters,.article-rail{position:static}.filter-list{grid-template-columns:repeat(2,minmax(0,1fr))}.filter-button{font-size:.82rem}}@media(max-width:540px){.shell{width:min(100% - 1.25rem,1160px)}.category-grid,.resource-grid{grid-template-columns:1fr}.category-card{min-height:0}.footer-inner{align-items:flex-start;flex-direction:column}.featured-search-control{align-items:stretch;flex-wrap:wrap}.featured-search input{width:calc(100% - 3rem)}.featured-search button{width:100%}}
</style>
